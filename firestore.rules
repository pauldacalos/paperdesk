// PaperDesk — Firestore Security Rules
//
// Current policy:
//   - Anyone can CREATE a submission (open system — no login required)
//   - No one can READ, UPDATE, or DELETE via client SDK (admin-only via Firebase Admin SDK)
//
// FUTURE: When admin dashboard is built, add:
//   allow read: if request.auth.token.admin == true;
// FUTURE: When reviewer system is built, add:
//   allow read: if request.auth.token.reviewer == true
//               && resource.data.reviewerId == request.auth.uid;

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /submissions/{submissionId} {

      // Allow anyone to create a new submission record
      // (file is already in Storage at this point, this just writes metadata)
      allow create: if request.resource.data.keys().hasAll([
                        'title', 'abstract', 'authors', 'keywords',
                        'fileUrl', 'status', 'createdAt'
                      ])
                    && request.resource.data.status == 'Submitted'
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0;

      // Block all reads and updates from the client
      // Admin access goes through Firebase Admin SDK (server-side only)
      allow read, update, delete: if false;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
